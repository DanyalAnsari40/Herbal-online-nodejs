<!DOCTYPE html>
<html lang="en">

<%- include('partials/modern-styles', { pageTitle: 'Tracking', extraCss: ['/css/style.css'] }) %>
<script type="module" src="/js/script.js" defer></script>

<body class="bg-white">
    <!-- Expose PostEx token for client-side fallback (mirrors create-order usage) -->
    <input type="hidden" id="postex_token" value="<%= (process && process.env && (process.env.POSTEX_API_TOKEN || process.env.POSTEX_TOKEN)) || '' %>">
    <% if (user.role==='admin' ) { %>
    <div class="min-h-screen flex">
      <!-- Sidebar -->
      <%- include('partials/modern-sidebar') %>

      <!-- Main Content -->
      <div class="flex-1 flex flex-col">
        <%- include('partials/modern-header', { pageTitle: 'Tracking' }) %>
        <% } else { %>
          <div class="min-h-screen flex">
            <%- include('partials/modern-sidebar') %>
            <div class="flex-1 flex flex-col">
              <%- include('partials/modern-header', { pageTitle: 'Tracking', user: user, currentRoute: currentRoute }) %>
        <% } %>

    </section>

    <main class="container mt-6">
        <!-- Courier selection buttons (outside of boxed form, like Create Order cards) -->
        <div class="mb-6">
            <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
                <button type="button" class="carrier-btn group flex items-center justify-center px-8 py-8 rounded-2xl stats-card shadow-2xl card-hover" data-carrier="TCS">
                    <i class="fas fa-shipping-fast mr-3 text-2xl group-hover:scale-110 transition-transform" style="color: #FCA311;"></i>
                    <span class="text-lg font-bold" style="color: #14213D;">TCS</span>
                </button>
                <button type="button" class="carrier-btn group flex items-center justify-center px-8 py-8 rounded-2xl stats-card shadow-2xl card-hover" data-carrier="LEOPARDS">
                    <i class="fas fa-truck mr-3 text-2xl group-hover:scale-110 transition-transform" style="color: #FCA311;"></i>
                    <span class="text-lg font-bold" style="color: #14213D;">Leopards</span>
                </button>
                <button type="button" class="carrier-btn group flex items-center justify-center px-8 py-8 rounded-2xl stats-card shadow-2xl card-hover" data-carrier="M&P">
                    <i class="fas fa-shipping-fast mr-3 text-2xl group-hover:scale-110 transition-transform" style="color: #FCA311;"></i>
                    <span class="text-lg font-bold" style="color: #14213D;">M&P</span>
                </button>
                <button type="button" class="carrier-btn group flex items-center justify-center px-8 py-8 rounded-2xl stats-card shadow-2xl card-hover" data-carrier="POSTEX">
                    <i class="fas fa-plane mr-3 text-2xl group-hover:scale-110 transition-transform" style="color: #FCA311;"></i>
                    <span class="text-lg font-bold" style="color: #14213D;">PostEx</span>
                </button>
            </div>
        </div>
    </main>

    <!-- Tracking ID Modal -->
    <div id="trackIdModal" class="modal-overlay">
      <div class="modal-container">
        <div class="modal-header">
          <h2>Enter Tracking No</h2>
          <button class="close-modal" id="trackIdClose"><i class="fas fa-times"></i></button>
        </div>
        <div class="modal-body">
          <div class="form-group">
            <label for="trackIdField" class="block text-sm font-semibold text-gray-700 mb-2">Enter Tracking No</label>
            <div style="position: relative;">
              <i class="fas fa-barcode" style="position:absolute; left:12px; top:50%; transform:translateY(-50%); color:#6c757d;"></i>
              <input type="text" id="trackIdField" class="w-full border rounded-lg px-10 py-3" required />
            </div>
          </div>
          <button id="trackIdSubmit" class="btn-track bg-[#F29C10]">
            <span class="btn-text">Track</span>
            <span class="btn-icon"><i class="fas fa-search-location"></i></span>
          </button>
        </div>
      </div>
    </div>

    <!-- Results Modal Popup -->
    <div class="modal-overlay" id="modalOverlay">
      <div class="modal-container">
        <div class="modal-header">
          <h2>Package Tracking Details</h2>
          <button class="close-modal" id="closeModal">
            <i class="fas fa-times"></i>
          </button>
        </div>
        <div class="modal-body">
          <div id="modalContent">
            <!-- Will dynamically contain either iframe OR tracking details -->
            <div class="tracking-header" id="trackingHeader"></div>
            <div class="timeline" id="timeline"></div>
          </div>
        </div>
      </div>
    </div>

    <script>
function toggleSidebar() {
  const sidebar = document.getElementById('sidebar');
  const texts = sidebar.querySelectorAll('.sidebar-text');
  const profilePic = sidebar.querySelector('.profile-pic-container');

  sidebar.classList.toggle('w-64');
  sidebar.classList.toggle('w-20');

  texts.forEach(el => el.classList.toggle('hidden'));

  profilePic.classList.toggle('w-24');
  profilePic.classList.toggle('h-24');
  profilePic.classList.toggle('w-12');
  profilePic.classList.toggle('h-12');

  sidebar.classList.toggle('p-6');
  sidebar.classList.toggle('p-2');
}
    </script>
</body>

</html>
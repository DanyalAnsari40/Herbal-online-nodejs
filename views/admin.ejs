<!DOCTYPE html>
<html lang="en">

<%- include('partials/modern-styles', { pageTitle: 'Dashboard' }) %>

<body class="bg-gray-50 font-inter antialiased">

  <% if (user.role==='admin') { %>
    <div class="min-h-screen flex">
      <%- include('partials/modern-sidebar') %>

      <div class="flex-1 flex flex-col min-w-0">
        <%- include('partials/modern-header', { pageTitle: 'Dashboard' }) %>

        <!-- Main Content Area -->
        <main class="flex-1 p-6 lg:p-10 overflow-y-auto">

          <!-- Welcome Banner -->
          <div class="mb-8">
            <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
              <div>
                <h2 class="text-3xl lg:text-4xl font-extrabold text-gray-900 tracking-tight">
                  Welcome back, <span class="text-transparent bg-clip-text" style="background-image: linear-gradient(135deg, #FCA311, #E8940F);"><%= user.displayName || 'Admin' %></span>
                </h2>
                <p class="mt-2 text-base text-gray-500">Here's what's happening with your business today.</p>
              </div>
              <div class="flex items-center gap-3">
                <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-semibold bg-green-50 text-green-700 border border-green-200">
                  <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
                  System Online
                </span>
                <span class="hidden sm:inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium bg-gray-100 text-gray-600 border border-gray-200">
                  <i class="far fa-calendar-alt"></i>
                  <script>document.write(new Date().toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' }))</script>
                </span>
              </div>
            </div>
          </div>

          <!-- Order Statistics -->
          <div class="mb-6">
            <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Order Overview</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-5">

              <!-- Total Orders -->
              <div class="group relative bg-white rounded-2xl p-6 shadow-sm border border-gray-100 hover:shadow-lg hover:border-blue-200 transition-all duration-300">
                <div class="flex items-start justify-between">
                  <div>
                    <p class="text-sm font-medium text-gray-500">Total Orders</p>
                    <p class="mt-2 text-4xl font-extrabold text-gray-900"><%= orderCount %></p>
                  </div>
                  <div class="w-12 h-12 rounded-xl bg-blue-50 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                    <i class="fas fa-shopping-bag text-blue-600 text-lg"></i>
                  </div>
                </div>
                <div class="absolute bottom-0 left-0 right-0 h-1 rounded-b-2xl bg-gradient-to-r from-blue-500 to-blue-600 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
              </div>

              <!-- Pending Orders -->
              <div class="group relative bg-white rounded-2xl p-6 shadow-sm border border-gray-100 hover:shadow-lg hover:border-amber-200 transition-all duration-300">
                <div class="flex items-start justify-between">
                  <div>
                    <p class="text-sm font-medium text-gray-500">Pending</p>
                    <p class="mt-2 text-4xl font-extrabold text-gray-900"><%= pendingOrderCount %></p>
                  </div>
                  <div class="w-12 h-12 rounded-xl bg-amber-50 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                    <i class="fas fa-clock text-amber-600 text-lg"></i>
                  </div>
                </div>
                <div class="absolute bottom-0 left-0 right-0 h-1 rounded-b-2xl bg-gradient-to-r from-amber-400 to-amber-500 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
              </div>

              <!-- Created Orders -->
              <div class="group relative bg-white rounded-2xl p-6 shadow-sm border border-gray-100 hover:shadow-lg hover:border-emerald-200 transition-all duration-300">
                <div class="flex items-start justify-between">
                  <div>
                    <p class="text-sm font-medium text-gray-500">Created</p>
                    <p class="mt-2 text-4xl font-extrabold text-gray-900"><%= createOrderCount %></p>
                  </div>
                  <div class="w-12 h-12 rounded-xl bg-emerald-50 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                    <i class="fas fa-plus-circle text-emerald-600 text-lg"></i>
                  </div>
                </div>
                <div class="absolute bottom-0 left-0 right-0 h-1 rounded-b-2xl bg-gradient-to-r from-emerald-500 to-emerald-600 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
              </div>

              <!-- Dispatched Orders -->
              <div class="group relative bg-white rounded-2xl p-6 shadow-sm border border-gray-100 hover:shadow-lg hover:border-violet-200 transition-all duration-300">
                <div class="flex items-start justify-between">
                  <div>
                    <p class="text-sm font-medium text-gray-500">Dispatched</p>
                    <p class="mt-2 text-4xl font-extrabold text-gray-900"><%= totalDispatchedOrders %></p>
                  </div>
                  <div class="w-12 h-12 rounded-xl bg-violet-50 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                    <i class="fas fa-truck text-violet-600 text-lg"></i>
                  </div>
                </div>
                <div class="absolute bottom-0 left-0 right-0 h-1 rounded-b-2xl bg-gradient-to-r from-violet-500 to-violet-600 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
              </div>

            </div>
          </div>

          <!-- Financial Overview -->
          <div class="mb-6">
            <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Financial Summary</h3>
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">

              <!-- Revenue -->
              <div class="relative overflow-hidden bg-white rounded-2xl p-6 shadow-sm border border-gray-100 hover:shadow-lg transition-all duration-300">
                <div class="flex items-start justify-between relative z-10">
                  <div>
                    <p class="text-sm font-medium text-gray-500">Total Revenue</p>
                    <p class="mt-2 text-3xl font-extrabold text-gray-900">Rs. <%= totalRevenue.toLocaleString() %></p>
                    <div class="mt-3 flex items-center gap-1">
                      <span class="inline-flex items-center gap-1 text-xs font-semibold text-emerald-600 bg-emerald-50 px-2 py-1 rounded-full">
                        <i class="fas fa-arrow-up text-[10px]"></i> Income
                      </span>
                    </div>
                  </div>
                  <div class="w-12 h-12 rounded-xl bg-emerald-50 flex items-center justify-center">
                    <i class="fas fa-wallet text-emerald-600 text-lg"></i>
                  </div>
                </div>
                <div class="absolute -bottom-4 -right-4 w-24 h-24 bg-emerald-50 rounded-full opacity-50"></div>
              </div>

              <!-- Cost -->
              <div class="relative overflow-hidden bg-white rounded-2xl p-6 shadow-sm border border-gray-100 hover:shadow-lg transition-all duration-300">
                <div class="flex items-start justify-between relative z-10">
                  <div>
                    <p class="text-sm font-medium text-gray-500">Total Cost</p>
                    <p class="mt-2 text-3xl font-extrabold text-gray-900">Rs. <%= totalCost.toLocaleString() %></p>
                    <div class="mt-3 flex items-center gap-1">
                      <span class="inline-flex items-center gap-1 text-xs font-semibold text-red-600 bg-red-50 px-2 py-1 rounded-full">
                        <i class="fas fa-arrow-down text-[10px]"></i> Expense
                      </span>
                    </div>
                  </div>
                  <div class="w-12 h-12 rounded-xl bg-red-50 flex items-center justify-center">
                    <i class="fas fa-receipt text-red-500 text-lg"></i>
                  </div>
                </div>
                <div class="absolute -bottom-4 -right-4 w-24 h-24 bg-red-50 rounded-full opacity-50"></div>
              </div>

              <!-- Profit -->
              <div class="relative overflow-hidden rounded-2xl p-6 shadow-sm border border-gray-100 hover:shadow-lg transition-all duration-300"
                   style="background: linear-gradient(135deg, #14213D 0%, #1E2A4A 100%);">
                <div class="flex items-start justify-between relative z-10">
                  <div>
                    <p class="text-sm font-medium text-gray-300">Net Profit</p>
                    <p class="mt-2 text-3xl font-extrabold text-white">Rs. <%= profit.toLocaleString() %></p>
                    <div class="mt-3 flex items-center gap-1">
                      <span class="inline-flex items-center gap-1 text-xs font-semibold px-2 py-1 rounded-full" 
                            style="background: rgba(252,163,17,0.2); color: #FCA311;">
                        <i class="fas fa-chart-line text-[10px]"></i> Balance
                      </span>
                    </div>
                  </div>
                  <div class="w-12 h-12 rounded-xl flex items-center justify-center" style="background: rgba(252,163,17,0.15);">
                    <i class="fas fa-coins text-lg" style="color: #FCA311;"></i>
                  </div>
                </div>
                <div class="absolute -bottom-4 -right-4 w-24 h-24 rounded-full opacity-20" style="background: #FCA311;"></div>
              </div>

            </div>
          </div>

          <!-- Team & Inventory -->
          <div class="mb-6">
            <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Resources</h3>
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">

              <!-- Employees -->
              <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 hover:shadow-lg transition-all duration-300">
                <div class="flex items-center justify-between mb-5">
                  <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-xl bg-indigo-50 flex items-center justify-center">
                      <i class="fas fa-users text-indigo-600 text-lg"></i>
                    </div>
                    <div>
                      <h4 class="text-base font-bold text-gray-900">Team Members</h4>
                      <p class="text-sm text-gray-500">Active employees</p>
                    </div>
                  </div>
                  <a href="/admin/employee-management" class="text-sm font-medium text-indigo-600 hover:text-indigo-700 transition-colors">
                    View all <i class="fas fa-arrow-right ml-1 text-xs"></i>
                  </a>
                </div>
                <div class="flex items-end justify-between bg-indigo-50/50 rounded-xl p-5">
                  <div>
                    <p class="text-5xl font-extrabold text-indigo-600"><%= employeeCount %></p>
                    <p class="text-sm text-gray-500 mt-1">Total Employees</p>
                  </div>
                  <div class="flex -space-x-2">
                    <div class="w-9 h-9 rounded-full bg-indigo-200 border-2 border-white flex items-center justify-center">
                      <i class="fas fa-user text-indigo-600 text-xs"></i>
                    </div>
                    <div class="w-9 h-9 rounded-full bg-indigo-300 border-2 border-white flex items-center justify-center">
                      <i class="fas fa-user text-indigo-700 text-xs"></i>
                    </div>
                    <div class="w-9 h-9 rounded-full bg-indigo-400 border-2 border-white flex items-center justify-center text-xs font-bold text-white">
                      +
                    </div>
                  </div>
                </div>
              </div>

              <!-- Products -->
              <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 hover:shadow-lg transition-all duration-300">
                <div class="flex items-center justify-between mb-5">
                  <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-xl bg-pink-50 flex items-center justify-center">
                      <i class="fas fa-box-open text-pink-600 text-lg"></i>
                    </div>
                    <div>
                      <h4 class="text-base font-bold text-gray-900">Product Catalog</h4>
                      <p class="text-sm text-gray-500">Inventory items</p>
                    </div>
                  </div>
                  <a href="/admin/product-management" class="text-sm font-medium text-pink-600 hover:text-pink-700 transition-colors">
                    View all <i class="fas fa-arrow-right ml-1 text-xs"></i>
                  </a>
                </div>
                <div class="flex items-end justify-between bg-pink-50/50 rounded-xl p-5">
                  <div>
                    <p class="text-5xl font-extrabold text-pink-600"><%= products.length %></p>
                    <p class="text-sm text-gray-500 mt-1">Products Available</p>
                  </div>
                  <div class="flex items-center gap-2">
                    <div class="w-9 h-9 rounded-full bg-pink-200 border-2 border-white flex items-center justify-center">
                      <i class="fas fa-box text-pink-600 text-xs"></i>
                    </div>
                    <div class="w-9 h-9 rounded-full bg-pink-300 border-2 border-white flex items-center justify-center">
                      <i class="fas fa-tags text-pink-700 text-xs"></i>
                    </div>
                  </div>
                </div>
              </div>

            </div>
          </div>

          <!-- Quick Actions -->
          <div class="mb-8">
            <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Quick Actions</h3>
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
              <% if (user.permissions && user.permissions.includes('orders')) { %>
              <a href="/admin/orders" class="group flex flex-col items-center gap-3 bg-white rounded-2xl p-5 shadow-sm border border-gray-100 hover:shadow-md hover:border-blue-200 transition-all duration-300">
                <div class="w-11 h-11 rounded-xl bg-blue-50 flex items-center justify-center group-hover:scale-110 transition-transform">
                  <i class="fas fa-list-alt text-blue-600"></i>
                </div>
                <span class="text-xs font-semibold text-gray-700 text-center">View Orders</span>
              </a>
              <% } %>
              <% if (user.permissions && user.permissions.includes('create-order')) { %>
              <a href="/admin/create-order" class="group flex flex-col items-center gap-3 bg-white rounded-2xl p-5 shadow-sm border border-gray-100 hover:shadow-md hover:border-emerald-200 transition-all duration-300">
                <div class="w-11 h-11 rounded-xl bg-emerald-50 flex items-center justify-center group-hover:scale-110 transition-transform">
                  <i class="fas fa-plus text-emerald-600"></i>
                </div>
                <span class="text-xs font-semibold text-gray-700 text-center">New Order</span>
              </a>
              <% } %>
              <% if (user.permissions && user.permissions.includes('employee-management')) { %>
              <a href="/admin/employee-management" class="group flex flex-col items-center gap-3 bg-white rounded-2xl p-5 shadow-sm border border-gray-100 hover:shadow-md hover:border-indigo-200 transition-all duration-300">
                <div class="w-11 h-11 rounded-xl bg-indigo-50 flex items-center justify-center group-hover:scale-110 transition-transform">
                  <i class="fas fa-user-plus text-indigo-600"></i>
                </div>
                <span class="text-xs font-semibold text-gray-700 text-center">Employees</span>
              </a>
              <% } %>
              <% if (user.permissions && user.permissions.includes('product-management')) { %>
              <a href="/admin/product-management" class="group flex flex-col items-center gap-3 bg-white rounded-2xl p-5 shadow-sm border border-gray-100 hover:shadow-md hover:border-pink-200 transition-all duration-300">
                <div class="w-11 h-11 rounded-xl bg-pink-50 flex items-center justify-center group-hover:scale-110 transition-transform">
                  <i class="fas fa-boxes text-pink-600"></i>
                </div>
                <span class="text-xs font-semibold text-gray-700 text-center">Products</span>
              </a>
              <% } %>
              <% if (user.permissions && user.permissions.includes('finance')) { %>
              <a href="/admin/finance" class="group flex flex-col items-center gap-3 bg-white rounded-2xl p-5 shadow-sm border border-gray-100 hover:shadow-md hover:border-amber-200 transition-all duration-300">
                <div class="w-11 h-11 rounded-xl bg-amber-50 flex items-center justify-center group-hover:scale-110 transition-transform">
                  <i class="fas fa-chart-pie text-amber-600"></i>
                </div>
                <span class="text-xs font-semibold text-gray-700 text-center">Finance</span>
              </a>
              <% } %>
              <% if (user.permissions && user.permissions.includes('track-product')) { %>
              <a href="/admin/tracking" class="group flex flex-col items-center gap-3 bg-white rounded-2xl p-5 shadow-sm border border-gray-100 hover:shadow-md hover:border-violet-200 transition-all duration-300">
                <div class="w-11 h-11 rounded-xl bg-violet-50 flex items-center justify-center group-hover:scale-110 transition-transform">
                  <i class="fas fa-map-marker-alt text-violet-600"></i>
                </div>
                <span class="text-xs font-semibold text-gray-700 text-center">Tracking</span>
              </a>
              <% } %>
            </div>
          </div>

          <!-- Footer -->
          <footer class="mt-auto pt-8 pb-4">
            <div class="border-t border-gray-200 pt-6 text-center">
              <p class="text-sm text-gray-400">&copy; 2025 Elite Admin Panel. All rights reserved.</p>
            </div>
          </footer>

        </main>
      </div>
    </div>

  <% } else { %>
    <!-- Employee Dashboard -->
    <div class="min-h-screen flex">
      <%- include('partials/modern-sidebar') %>

      <div class="flex-1 flex flex-col min-w-0">
        <%- include('partials/modern-header', { pageTitle: 'Dashboard', user: user, currentRoute: currentRoute }) %>

        <main class="flex-1 p-6 lg:p-10 overflow-y-auto">

          <!-- Employee Welcome -->
          <div class="mb-10">
            <h2 class="text-3xl lg:text-4xl font-extrabold text-gray-900 tracking-tight">
              Welcome back, <span class="text-transparent bg-clip-text" style="background-image: linear-gradient(135deg, #FCA311, #E8940F);"><%= user.displayName || 'Team Member' %></span>
            </h2>
            <p class="mt-2 text-base text-gray-500">Here's your personal activity summary.</p>
          </div>

          <!-- Employee Stats -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-2xl mx-auto">

            <!-- Orders Created -->
            <div class="group bg-white rounded-2xl p-8 shadow-sm border border-gray-100 hover:shadow-lg hover:border-blue-200 transition-all duration-300 text-center">
              <div class="w-16 h-16 rounded-2xl bg-blue-50 flex items-center justify-center mx-auto mb-5 group-hover:scale-110 transition-transform duration-300">
                <i class="fas fa-box text-blue-600 text-2xl"></i>
              </div>
              <p class="text-5xl font-extrabold text-gray-900 mb-2"><%= createOrderCount %></p>
              <p class="text-sm font-semibold text-gray-500">Orders Created by You</p>
            </div>

            <!-- Orders Dispatched -->
            <div class="group bg-white rounded-2xl p-8 shadow-sm border border-gray-100 hover:shadow-lg hover:border-indigo-200 transition-all duration-300 text-center">
              <div class="w-16 h-16 rounded-2xl bg-indigo-50 flex items-center justify-center mx-auto mb-5 group-hover:scale-110 transition-transform duration-300">
                <i class="fas fa-shipping-fast text-indigo-600 text-2xl"></i>
              </div>
              <p class="text-5xl font-extrabold text-gray-900 mb-2"><%= totalDispatchedOrders %></p>
              <p class="text-sm font-semibold text-gray-500">Orders You Dispatched</p>
            </div>

          </div>

          <!-- Footer -->
          <footer class="mt-auto pt-12 pb-4">
            <div class="border-t border-gray-200 pt-6 text-center">
              <p class="text-sm text-gray-400">&copy; 2025 Elite Admin Panel. All rights reserved.</p>
            </div>
          </footer>

        </main>
      </div>
    </div>
  <% } %>

  <!-- Profile Modal -->
  <div id="profileModal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm">
    <div class="bg-white p-8 rounded-2xl w-full max-w-md shadow-2xl border border-gray-100 mx-4">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold text-gray-900">Profile</h2>
        <button onclick="document.getElementById('profileModal').classList.add('hidden')"
          class="w-8 h-8 rounded-lg bg-gray-100 hover:bg-gray-200 flex items-center justify-center transition-colors">
          <i class="fas fa-times text-gray-500 text-sm"></i>
        </button>
      </div>
      <div class="flex items-center gap-4 mb-6 p-4 bg-gray-50 rounded-xl">
        <img src="<%= getProfilePicUrl(user.profilePic) %>" alt="Profile"
          class="w-14 h-14 rounded-full object-cover border-2 border-gray-200">
        <div>
          <p class="font-bold text-gray-900 text-lg"><%= user.displayName %></p>
          <p class="text-gray-500 text-sm"><%= user.email %></p>
        </div>
      </div>
      <div class="flex justify-end gap-3">
        <button onclick="document.getElementById('profileModal').classList.add('hidden')"
          class="px-5 py-2.5 rounded-xl bg-gray-100 text-gray-700 font-semibold hover:bg-gray-200 transition-colors text-sm">Cancel</button>
        <button
          onclick="document.getElementById('editProfileModal').classList.remove('hidden'); document.getElementById('profileModal').classList.add('hidden');"
          class="px-5 py-2.5 rounded-xl text-white font-semibold transition-colors text-sm"
          style="background: linear-gradient(135deg, #FCA311, #E8940F);">Edit Profile</button>
      </div>
    </div>
  </div>

  <!-- Edit Profile Modal -->
  <div id="editProfileModal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm">
    <div class="bg-white p-8 rounded-2xl w-full max-w-md shadow-2xl border border-gray-100 mx-4">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold text-gray-900">Edit Profile</h2>
        <button onclick="document.getElementById('editProfileModal').classList.add('hidden')"
          class="w-8 h-8 rounded-lg bg-gray-100 hover:bg-gray-200 flex items-center justify-center transition-colors">
          <i class="fas fa-times text-gray-500 text-sm"></i>
        </button>
      </div>
      <form method="POST" action="/admin/profile" enctype="multipart/form-data">
        <div class="mb-5">
          <label class="block text-sm font-semibold text-gray-700 mb-2">Display Name</label>
          <input type="text" name="displayName" value="<%= user.displayName || '' %>"
            class="w-full border border-gray-200 bg-gray-50 p-3 rounded-xl focus:outline-none focus:ring-2 focus:border-transparent text-sm"
            style="focus:ring-color: #FCA311;">
        </div>
        <div class="mb-6">
          <label class="block text-sm font-semibold text-gray-700 mb-2">Profile Picture</label>
          <input type="file" name="profilePic"
            class="w-full border border-gray-200 bg-gray-50 p-3 rounded-xl focus:outline-none focus:ring-2 focus:border-transparent text-sm file:mr-4 file:py-1 file:px-3 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-amber-50 file:text-amber-700 hover:file:bg-amber-100">
        </div>
        <div class="flex justify-end gap-3">
          <button type="button" onclick="document.getElementById('editProfileModal').classList.add('hidden')"
            class="px-5 py-2.5 rounded-xl bg-gray-100 text-gray-700 font-semibold hover:bg-gray-200 transition-colors text-sm">Cancel</button>
          <button type="submit"
            class="px-5 py-2.5 rounded-xl text-white font-semibold transition-colors text-sm"
            style="background: linear-gradient(135deg, #FCA311, #E8940F);">Save Changes</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    function toggleSidebar() {
      const sidebar = document.getElementById('sidebar');
      const texts = document.querySelectorAll('.sidebar-text');
      const profilePic = document.querySelector('.profile-pic-container');

      sidebar.classList.toggle('w-64');
      sidebar.classList.toggle('w-16');

      texts.forEach(el => el.classList.toggle('hidden'));

      if (profilePic) {
        profilePic.classList.toggle('w-24');
        profilePic.classList.toggle('h-24');
        profilePic.classList.toggle('w-12');
        profilePic.classList.toggle('h-12');
      }

      sidebar.classList.toggle('p-6');
      sidebar.classList.toggle('p-2');
    }
  </script>

</body>

</html>

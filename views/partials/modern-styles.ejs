<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>🚀 <%= pageTitle || 'Elite Admin Panel' %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="//unpkg.com/alpinejs" defer></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <% if (typeof extraCss !== 'undefined' && Array.isArray(extraCss)) { %>
    <% extraCss.forEach(function(href) { %>
      <link rel="stylesheet" href="<%= href %>">
    <% }) %>
  <% } %>
  
  <style>
    /*
      Global scale: Set base font-size to 12px (~75% of default 16px) on large screens.
      This scales Tailwind REM-based utilities consistently across the app.
      On smaller screens, keep 16px for readability.
    */
    html {
      font-size: 10px; /* 75% scale on desktops */
    }
    @media (max-width: 1279px) {
      html {
        font-size: 14px; /* reset for tablets/phones */
      }
    }

    :root {
      --primary-white: #FFFFFF;
      --primary-gray: #E5E5E5;
      --primary-orange: #FCA311;
      --primary-dark: #14213D;
      --primary-black: #000000;
      --orange-light: #FFB84D;
      --orange-dark: #E8940F;
      --dark-light: #1E2A4A;
      --dark-darker: #0F1729;
    }
    
    body {
      font-family: 'Inter', sans-serif;
      background: #ffffff;
    }
    
    .glass { 
      background: rgba(255, 255, 255, 0.15); 
      backdrop-filter: blur(20px); 
      border: 1px solid rgba(252, 163, 17, 0.2); 
    }
    
    .glass-dark {
      background: rgba(20, 33, 61, 0.9);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(252, 163, 17, 0.3);
    }
    
    .card-hover { 
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); 
    }
    
    .card-hover:hover { 
      transform: translateY(-8px) scale(1.02); 
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25); 
    }
    
    .stats-card { 
      background: linear-gradient(135deg, var(--primary-white) 0%, var(--primary-gray) 100%); 
      backdrop-filter: blur(20px); 
      border: 1px solid var(--primary-orange); 
      transition: all 0.3s ease; 
      color: var(--primary-dark);
    }
    
    .stats-card:hover { 
      transform: translateY(-5px); 
      box-shadow: 0 20px 40px rgba(252, 163, 17, 0.3); 
      border-color: var(--orange-light); 
    }
    
    .gradient-text { 
      background: linear-gradient(135deg, var(--primary-orange) 0%, var(--orange-dark) 100%); 
      -webkit-background-clip: text; 
      -webkit-text-fill-color: transparent; 
      background-clip: text; 
    }
    
    .neon-glow {
      box-shadow: 0 0 5px currentColor, 0 0 20px currentColor, 0 0 35px currentColor;
    }
    
    @keyframes float { 
      0%, 100% { transform: translateY(0px); } 
      50% { transform: translateY(-10px); } 
    }
    
    .floating { 
      animation: float 3s ease-in-out infinite; 
    }
    
    @keyframes pulse-glow {
      0%, 100% { box-shadow: 0 0 5px rgba(59, 130, 246, 0.5); }
      50% { box-shadow: 0 0 20px rgba(59, 130, 246, 0.8), 0 0 30px rgba(59, 130, 246, 0.6); }
    }
    
    .pulse-glow {
      animation: pulse-glow 2s ease-in-out infinite;
    }
    
    .sidebar-item { 
      position: relative; 
      overflow: hidden; 
    }
    
    .sidebar-item::before { 
      content: ''; 
      position: absolute; 
      top: 0; 
      left: -100%; 
      width: 100%; 
      height: 100%; 
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent); 
      transition: left 0.5s; 
    }
    
    .sidebar-item:hover::before { 
      left: 100%; 
    }
    
    .modern-table {
      background: rgba(255, 255, 255, 0.05);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    .modern-table th {
      background: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(10px);
    }
    
    .modern-table tr:hover {
      background: rgba(255, 255, 255, 0.05);
      transform: scale(1.01);
      transition: all 0.2s ease;
    }
    
    .modern-button {
      background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0.05) 100%);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(255,255,255,0.2);
      transition: all 0.3s ease;
    }
    
    .modern-button:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 25px rgba(0,0,0,0.1);
      border-color: rgba(255,255,255,0.3);
    }
    
    .modern-input {
      background: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.2);
      transition: all 0.3s ease;
    }
    
    .modern-input:focus {
      background: rgba(255, 255, 255, 0.15);
      border-color: rgba(59, 130, 246, 0.5);
      box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
    }
    
    .loading-spinner {
      border: 3px solid rgba(255, 255, 255, 0.3);
      border-radius: 50%;
      border-top: 3px solid #fff;
      width: 20px;
      height: 20px;
      animation: spin 1s linear infinite;
    }
    
    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }
    
    .notification-badge {
      background: linear-gradient(135deg, #ff6b6b, #ee5a24);
      animation: pulse 2s infinite;
    }
    
    .success-glow {
      box-shadow: 0 0 20px rgba(34, 197, 94, 0.4);
    }
    
    .error-glow {
      box-shadow: 0 0 20px rgba(239, 68, 68, 0.4);
    }
    
    .warning-glow {
      box-shadow: 0 0 20px rgba(245, 158, 11, 0.4);
    }
  </style>
</head>

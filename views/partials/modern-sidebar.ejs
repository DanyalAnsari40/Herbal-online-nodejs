<!-- Modern Professional Sidebar -->
<aside id="sidebar"
  class="w-72 transition-all duration-500 text-white flex flex-col p-6 space-y-6 border-r shadow-xl flex-shrink-0"
  style="background: linear-gradient(180deg, #14213D 0%, #0F1729 100%); border-color: rgba(255,255,255,0.08);">
  
  <!-- Profile Section -->
  <div class="flex flex-col items-center space-y-4 rounded-2xl p-5" style="background: rgba(255,255,255,0.06);">
    <div class="relative">
      <div class="w-20 h-20 rounded-2xl overflow-hidden border-2 p-0.5" style="border-color: rgba(252,163,17,0.4); background: rgba(252,163,17,0.1);">
        <img src="<%= getProfilePicUrlLarge(user.profilePic) %>" alt="Profile"
          class="w-full h-full object-cover rounded-xl bg-white">
      </div>
      <div class="absolute -bottom-1 -right-1 w-6 h-6 rounded-lg flex items-center justify-center" style="background: #FCA311;">
        <i class="fas fa-check text-white" style="font-size: 8px;"></i>
      </div>
    </div>
    <div class="text-center space-y-1">
      <h3 class="text-base font-bold text-white truncate max-w-[180px]">
        <%= user.displayName || 'Elite Admin' %>
      </h3>
      <p class="text-xs text-gray-400 truncate max-w-[180px]">
        <%= user.email %>
      </p>
      <span class="inline-block rounded-lg px-3 py-1 text-[10px] font-bold uppercase tracking-wider text-white mt-1" style="background: rgba(252,163,17,0.2); color: #FCA311;">
        <%= user.role %>
      </span>
    </div>
  </div>

  <!-- Navigation -->
  <nav class="flex flex-col space-y-1.5 flex-1">
    <div class="text-[10px] font-semibold uppercase tracking-widest mb-2 px-4 text-gray-500">
      Navigation
    </div>
    
    <a href="/admin"
      class="sidebar-item group flex items-center px-4 py-3 rounded-xl transition-all duration-200 <%= currentRoute === 'admin' ? 'shadow-md' : 'hover:bg-white/[0.06]' %>"
      <% if (currentRoute === 'admin') { %>style="background: rgba(252, 163, 17, 0.15);"<% } %>>
      <div class="flex items-center justify-center w-9 h-9 rounded-lg mr-3 transition-transform <%= currentRoute === 'admin' ? '' : 'group-hover:scale-105' %>"
           style="background: <%= currentRoute === 'admin' ? '#FCA311' : 'rgba(255,255,255,0.08)' %>;">
        <i class="fas fa-home text-white text-sm"></i>
      </div>
      <span class="sidebar-text text-sm font-medium <%= currentRoute === 'admin' ? 'text-white' : 'text-gray-300' %>">Dashboard</span>
      <% if (currentRoute === 'admin') { %>
        <div class="ml-auto w-1.5 h-1.5 rounded-full" style="background: #FCA311;"></div>
      <% } %>
    </a>

    <a href="/admin/attendence"
      class="sidebar-item group flex items-center px-4 py-3 rounded-xl transition-all duration-200 <%= currentRoute === 'attendence' ? 'shadow-md' : 'hover:bg-white/[0.06]' %>"
      <% if (currentRoute === 'attendence') { %>style="background: rgba(252, 163, 17, 0.15);"<% } %>>
      <div class="flex items-center justify-center w-9 h-9 rounded-lg mr-3 transition-transform <%= currentRoute === 'attendence' ? '' : 'group-hover:scale-105' %>"
           style="background: <%= currentRoute === 'attendence' ? '#FCA311' : 'rgba(255,255,255,0.08)' %>;">
        <i class="fa-solid fa-user-clock text-white text-sm"></i>
      </div>
      <span class="sidebar-text text-sm font-medium <%= currentRoute === 'attendence' ? 'text-white' : 'text-gray-300' %>">Attendance</span>
      <% if (currentRoute === 'attendence') { %>
        <div class="ml-auto w-1.5 h-1.5 rounded-full" style="background: #FCA311;"></div>
      <% } %>
    </a>
    
    <% if (user.permissions && user.permissions.includes('orders')) { %>
      <a href="/admin/orders"
        class="sidebar-item group flex items-center px-4 py-3 rounded-xl transition-all duration-200 <%= currentRoute === 'orders' ? 'shadow-md' : 'hover:bg-white/[0.06]' %>"
        <% if (currentRoute === 'orders') { %>style="background: rgba(252, 163, 17, 0.15);"<% } %>>
        <div class="flex items-center justify-center w-9 h-9 rounded-lg mr-3 transition-transform <%= currentRoute === 'orders' ? '' : 'group-hover:scale-105' %>"
             style="background: <%= currentRoute === 'orders' ? '#FCA311' : 'rgba(255,255,255,0.08)' %>;">
          <i class="fas fa-shopping-cart text-white text-sm"></i>
        </div>
        <span class="sidebar-text text-sm font-medium <%= currentRoute === 'orders' ? 'text-white' : 'text-gray-300' %>">Orders</span>
        <% if (currentRoute === 'orders') { %>
          <div class="ml-auto w-1.5 h-1.5 rounded-full" style="background: #FCA311;"></div>
        <% } %>
      </a>
    <% } %>

    <% if (user.permissions && user.permissions.includes('create-order')) { %>
      <a href="/admin/create-order"
        class="sidebar-item group flex items-center px-4 py-3 rounded-xl transition-all duration-200 <%= currentRoute === 'create-order' ? 'shadow-md' : 'hover:bg-white/[0.06]' %>"
        <% if (currentRoute === 'create-order') { %>style="background: rgba(252, 163, 17, 0.15);"<% } %>>
        <div class="flex items-center justify-center w-9 h-9 rounded-lg mr-3 transition-transform <%= currentRoute === 'create-order' ? '' : 'group-hover:scale-105' %>"
             style="background: <%= currentRoute === 'create-order' ? '#FCA311' : 'rgba(255,255,255,0.08)' %>;">
          <i class="fas fa-plus-circle text-white text-sm"></i>
        </div>
        <span class="sidebar-text text-sm font-medium <%= currentRoute === 'create-order' ? 'text-white' : 'text-gray-300' %>">Create Order</span>
        <% if (currentRoute === 'create-order') { %>
          <div class="ml-auto w-1.5 h-1.5 rounded-full" style="background: #FCA311;"></div>
        <% } %>
      </a>
    <% } %>
    
    <% if (user.permissions.includes('employee-management')) { %>
      <a href="/admin/employee-management"
        class="sidebar-item group flex items-center px-4 py-3 rounded-xl transition-all duration-200 <%= currentRoute === 'employee-management' ? 'shadow-md' : 'hover:bg-white/[0.06]' %>"
        <% if (currentRoute === 'employee-management') { %>style="background: rgba(252, 163, 17, 0.15);"<% } %>>
        <div class="flex items-center justify-center w-9 h-9 rounded-lg mr-3 transition-transform <%= currentRoute === 'employee-management' ? '' : 'group-hover:scale-105' %>"
             style="background: <%= currentRoute === 'employee-management' ? '#FCA311' : 'rgba(255,255,255,0.08)' %>;">
          <i class="fas fa-users text-white text-sm"></i>
        </div>
        <span class="sidebar-text text-sm font-medium <%= currentRoute === 'employee-management' ? 'text-white' : 'text-gray-300' %>">Employees</span>
        <% if (currentRoute === 'employee-management') { %>
          <div class="ml-auto w-1.5 h-1.5 rounded-full" style="background: #FCA311;"></div>
        <% } %>
      </a>
    <% } %>
    
    <% if (user.permissions.includes('product-management')) { %>
      <a href="/admin/product-management"
        class="sidebar-item group flex items-center px-4 py-3 rounded-xl transition-all duration-200 <%= currentRoute === 'product-management' ? 'shadow-md' : 'hover:bg-white/[0.06]' %>"
        <% if (currentRoute === 'product-management') { %>style="background: rgba(252, 163, 17, 0.15);"<% } %>>
        <div class="flex items-center justify-center w-9 h-9 rounded-lg mr-3 transition-transform <%= currentRoute === 'product-management' ? '' : 'group-hover:scale-105' %>"
             style="background: <%= currentRoute === 'product-management' ? '#FCA311' : 'rgba(255,255,255,0.08)' %>;">
          <i class="fas fa-boxes text-white text-sm"></i>
        </div>
        <span class="sidebar-text text-sm font-medium <%= currentRoute === 'product-management' ? 'text-white' : 'text-gray-300' %>">Products</span>
        <% if (currentRoute === 'product-management') { %>
          <div class="ml-auto w-1.5 h-1.5 rounded-full" style="background: #FCA311;"></div>
        <% } %>
      </a>
    <% } %>
    
    <% if (user.permissions.includes('track-product')) { %>
      <a href="/admin/tracking"
        class="sidebar-item group flex items-center px-4 py-3 rounded-xl transition-all duration-200 <%= currentRoute === 'tracking' ? 'shadow-md' : 'hover:bg-white/[0.06]' %>"
        <% if (currentRoute === 'tracking') { %>style="background: rgba(252, 163, 17, 0.15);"<% } %>>
        <div class="flex items-center justify-center w-9 h-9 rounded-lg mr-3 transition-transform <%= currentRoute === 'tracking' ? '' : 'group-hover:scale-105' %>"
             style="background: <%= currentRoute === 'tracking' ? '#FCA311' : 'rgba(255,255,255,0.08)' %>;">
          <i class="fa-solid fa-truck text-white text-sm"></i>
        </div>
        <span class="sidebar-text text-sm font-medium <%= currentRoute === 'tracking' ? 'text-white' : 'text-gray-300' %>">Tracking</span>
        <% if (currentRoute === 'tracking') { %>
          <div class="ml-auto w-1.5 h-1.5 rounded-full" style="background: #FCA311;"></div>
        <% } %>
      </a>
    <% } %>
    
    <% if (user.permissions.includes('finance')) { %>
      <a href="/admin/finance"
        class="sidebar-item group flex items-center px-4 py-3 rounded-xl transition-all duration-200 <%= currentRoute === 'finance' ? 'shadow-md' : 'hover:bg-white/[0.06]' %>"
        <% if (currentRoute === 'finance') { %>style="background: rgba(252, 163, 17, 0.15);"<% } %>>
        <div class="flex items-center justify-center w-9 h-9 rounded-lg mr-3 transition-transform <%= currentRoute === 'finance' ? '' : 'group-hover:scale-105' %>"
             style="background: <%= currentRoute === 'finance' ? '#FCA311' : 'rgba(255,255,255,0.08)' %>;">
          <i class="fas fa-coins text-white text-sm"></i>
        </div>
        <span class="sidebar-text text-sm font-medium <%= currentRoute === 'finance' ? 'text-white' : 'text-gray-300' %>">Finance</span>
        <% if (currentRoute === 'finance') { %>
          <div class="ml-auto w-1.5 h-1.5 rounded-full" style="background: #FCA311;"></div>
        <% } %>
      </a>
    <% } %>
  </nav>

  <!-- Sidebar Footer -->
  <div class="pt-4 border-t border-white/[0.08]">
    <div class="flex items-center gap-3 px-4 py-2">
      <div class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></div>
      <span class="text-xs text-gray-500">System Online</span>
    </div>
  </div>
</aside>

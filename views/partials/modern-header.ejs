<!-- Modern Professional Header -->
<header class="bg-white/80 backdrop-blur-xl shadow-sm border-b border-gray-200 sticky top-0 z-30">
  <div class="px-6 lg:px-10 py-4">
    <div class="flex justify-between items-center">
      <div class="flex items-center gap-4">
        <!-- Toggle Button -->
        <button onclick="toggleSidebar()" class="group p-2.5 rounded-xl bg-gray-100 hover:bg-gray-200 transition-all duration-200">
          <i class="fas fa-bars text-gray-600 text-sm"></i>
        </button>

        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center shadow-sm" style="background: linear-gradient(135deg, #FCA311 0%, #E8940F 100%);">
            <i class="fas fa-bolt text-white text-sm"></i>
          </div>
          <div>
            <h1 class="text-xl lg:text-2xl font-extrabold text-gray-900 tracking-tight">
              <%= pageTitle || 'Dashboard' %>
              <span id="pwa-indicator" class="hidden ml-2 px-2 py-0.5 text-[10px] font-bold rounded-full text-white" style="background: #FCA311;">PWA</span>
            </h1>
          </div>
        </div>
      </div>
      
      <!-- Center Refresh -->
      <div class="hidden md:flex flex-1 justify-center">
        <button onclick="refreshApp()" title="Refresh App"
          class="group p-2.5 rounded-xl bg-gray-100 hover:bg-gray-200 transition-all duration-200">
          <i class="fas fa-sync-alt text-gray-500 text-sm group-hover:rotate-180 transition-transform duration-500"></i>
        </button>
      </div>
      
      <!-- Quick Actions -->
      <div class="flex items-center gap-3">
        <% if (user.permissions.includes('orders')) { %>
          <a href="/admin/orders"
            class="hidden lg:flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-medium transition-all duration-200 <%= currentRoute === 'orders' ? 'bg-gray-900 text-white shadow-md' : 'bg-gray-100 text-gray-700 hover:bg-gray-200' %>">
            <i class="fas fa-shopping-cart text-xs"></i>
            <span>Orders</span>
          </a>
        <% } %>
        
        <% if (user.permissions.includes('create-order')) { %>
          <a href="/admin/create-order"
            class="hidden lg:flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-semibold text-white shadow-md hover:shadow-lg transition-all duration-200"
            style="background: linear-gradient(135deg, #FCA311 0%, #E8940F 100%);">
            <i class="fas fa-plus text-xs"></i>
            <span>New Order</span>
          </a>
        <% } %>
        
        <!-- User Actions -->
        <div class="flex items-center gap-2 ml-2 pl-4 border-l border-gray-200">
          <button onclick="document.getElementById('profileModal').classList.remove('hidden')"
            class="p-2.5 rounded-xl bg-gray-100 hover:bg-gray-200 transition-all duration-200">
            <i class="fas fa-user text-gray-600 text-sm"></i>
          </button>
          
          <a href="/logout"
            class="flex items-center gap-2 px-4 py-2 rounded-xl bg-red-50 text-red-600 text-sm font-semibold hover:bg-red-100 transition-all duration-200">
            <i class="fas fa-sign-out-alt text-xs"></i>
            <span class="hidden sm:inline">Logout</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</header>
